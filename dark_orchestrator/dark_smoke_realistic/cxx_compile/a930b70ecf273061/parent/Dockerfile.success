# ------------------------------------------------------------
#  Base image – recent Ubuntu LTS (22.04 at the time)
# ------------------------------------------------------------
FROM ubuntu:22.04

# ------------------------------------------------------------
#  Make apt non‑interactive and switch to a fast mirror
# ------------------------------------------------------------
ENV DEBIAN_FRONTEND=noninteractive

# ------------------------------------------------------------
#  Use the Aliyun mirror, update the package index and upgrade
# ------------------------------------------------------------
RUN sed -i 's|http://archive.ubuntu.com/ubuntu/|http://mirrors.aliyun.com/ubuntu/|g' /etc/apt/sources.list && \
    sed -i 's|http://security.ubuntu.com/ubuntu/|http://mirrors.aliyun.com/ubuntu/|g' /etc/apt/sources.list && \
    apt-get update && \
    apt-get upgrade -y

# ------------------------------------------------------------
#  Core build tools
# ------------------------------------------------------------
RUN apt-get install -y build-essential

# ------------------------------------------------------------
#  Helpful utilities
# ------------------------------------------------------------
RUN apt-get install -y software-properties-common

# ------------------------------------------------------------
#  Project‑specific dependencies (one install per RUN)
# ------------------------------------------------------------
RUN apt-get install -y cmake
RUN apt-get install -y pkg-config
RUN apt-get install -y libcurl4-openssl-dev
RUN apt-get install -y python3-dev
RUN apt-get install -y python3-setuptools

# ------------------------------------------------------------
#  Clean apt cache to keep the image small
# ------------------------------------------------------------
RUN apt-get clean && rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------------
#  Copy the source code into the container (temporary build area)
# ------------------------------------------------------------
COPY ./a930b70ecf273061_parent /tmp/a930b70ecf273061_parent

# ------------------------------------------------------------
#  Build the project with CMake
# ------------------------------------------------------------
WORKDIR /tmp/a930b70ecf273061_parent

# Configure the build
RUN cmake -S . -B build

# Compile (use all available CPUs)
RUN cmake --build build -j$(nproc)

# (Optional) Install the library into the system
# RUN cmake --install build

# ------------------------------------------------------------
#  Default command – keep the container alive for debugging
# ------------------------------------------------------------
CMD ["/bin/bash"]