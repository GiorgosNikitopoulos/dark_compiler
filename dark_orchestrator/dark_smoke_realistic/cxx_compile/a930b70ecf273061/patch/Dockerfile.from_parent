FROM dark_cxx/20260601_021730_957e/a930b70ecf273061/parent:v1
RUN rm -rf /tmp/a930b70ecf273061_parent
COPY ./a930b70ecf273061_patch /tmp/a930b70ecf273061_parent

# ------------------------------------------------------------
#  Build the project with CMake
# ------------------------------------------------------------
WORKDIR /tmp/a930b70ecf273061_parent

# Configure the build
RUN cmake -S . -B build

# Compile (use all available CPUs)
RUN cmake --build build -j$(nproc)

# (Optional) Install the library into the system
# RUN cmake --install build

# ------------------------------------------------------------
#  Default command – keep the container alive for debugging
# ------------------------------------------------------------
CMD ["/bin/bash"]
