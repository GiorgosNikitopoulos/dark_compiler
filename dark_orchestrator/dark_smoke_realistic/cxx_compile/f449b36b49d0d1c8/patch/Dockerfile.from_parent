FROM dark_cxx/20260601_021730_957e/f449b36b49d0d1c8/parent:v1
RUN rm -rf /tmp/project
COPY ./f449b36b49d0d1c8_patch /tmp/project

# ------------------------------------------------------------
# Build the project using CMake
# ------------------------------------------------------------
WORKDIR /tmp/project

RUN mkdir build

WORKDIR /tmp/project/build

RUN cmake ..

RUN make -j$(nproc)

# ------------------------------------------------------------
# Default command (keep container alive for interactive use)
# ------------------------------------------------------------
CMD ["/bin/bash"]
