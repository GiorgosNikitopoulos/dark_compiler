# ------------------------------------------------------------
# Base image – use a recent Ubuntu LTS release
# ------------------------------------------------------------
FROM ubuntu:22.04

# ------------------------------------------------------------
# Non‑interactive apt (prevents tzdata & other prompts)
# ------------------------------------------------------------
ENV DEBIAN_FRONTEND=noninteractive

# ------------------------------------------------------------
# Switch to fast Chinese mirrors, update the package index and
# upgrade existing packages
# ------------------------------------------------------------
RUN sed -i 's|http://archive.ubuntu.com/ubuntu/|http://mirrors.aliyun.com/ubuntu/|g' /etc/apt/sources.list \
    && sed -i 's|http://security.ubuntu.com/ubuntu/|http://mirrors.aliyun.com/ubuntu/|g' /etc/apt/sources.list \
    && apt-get update \
    && apt-get upgrade -y

# ------------------------------------------------------------
# Install the basic development tools (one command per RUN)
# ------------------------------------------------------------
RUN apt-get install -y build-essential
RUN apt-get install -y software-properties-common
RUN apt-get install -y cmake
RUN apt-get install -y pkg-config
RUN apt-get install -y git

# ------------------------------------------------------------
# Install the cJSON development library (required for linking)
# ------------------------------------------------------------
RUN apt-get install -y libcjson-dev

# ------------------------------------------------------------
# Copy the project source into the container (temp directory)
# ------------------------------------------------------------
COPY 825bb04d4575f866_parent /tmp/src

# ------------------------------------------------------------
# Set the working directory to the source location
# ------------------------------------------------------------
WORKDIR /tmp/src

# ------------------------------------------------------------
# **Fix:** Replace the erroneous reference to the object file
#          “cJSON.o” with the proper linker flag “-lcjson”.
#          This is done with a single‑line sed edit so that the
#          original Makefile stays untouched apart from this
#          substitution.
# ------------------------------------------------------------
RUN sed -i 's/cJSON\.o/-lcjson/g' Makefile

# ------------------------------------------------------------
# Build the project with the provided Makefile
# ------------------------------------------------------------
RUN make -j$(nproc)

# ------------------------------------------------------------
# (Optional) Install the library into the image
# ------------------------------------------------------------
RUN make install

# ------------------------------------------------------------
# Clean up apt cache to keep the image size small
# ------------------------------------------------------------
RUN apt-get clean && rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------------
# Default command – keep the container alive (adjust as needed)
# ------------------------------------------------------------
CMD ["bash"]